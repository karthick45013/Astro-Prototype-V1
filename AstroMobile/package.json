{
  "name": "astro-mobile",
  "version": "0.1.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "web": "expo start --web",
    "build:android": "eas build -p android --profile preview",
    "build:android-store": "eas build -p android --profile production",
    "build:android-local": "expo prebuild -p android --clean && cd android && gradlew.bat assembleDebug"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^1.23.1",
    "expo": "~51.0.0",
    "expo-camera": "~15.0.16",
    "expo-status-bar": "~1.12.1",
    "react": "18.2.0",
    "react-native": "0.74.5"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0"
  }
}
